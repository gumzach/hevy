# ============================================
# Local Development Configuration
# ============================================
ENVIRONMENT=local
# Simulates credentials that users provide in gumstack frontend
LOCAL_API_KEY=your_api_key_here

# ============================================
# Gumstack Configuration (set by gumstack in production)
# ============================================
GUMSTACK_SERVER_ID=hevy
# GUMSTACK_BACKEND_URL=https://api.gumstack.com
# GUMLOOP_BACKEND_URL=https://api.gumloop.com
